<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Merge into ios/App/App/Info.plist under the root <dict> if missing after cap add ios.
  Used for Supabase OAuth redirect: ca.popuphub.app://auth/callback
-->
<plist version="1.0">
<dict>
  <key>CFBundleURLTypes</key>
  <array>
    <dict>
      <key>CFBundleURLName</key>
      <string>ca.popuphub.app</string>
      <key>CFBundleURLSchemes</key>
      <array>
        <string>ca.popuphub.app</string>
      </array>
    </dict>
  </array>
</dict>
</plist>
