{
  "_comment": "Copy to google-services.json after creating a Firebase project for ca.popuphub.app.",
  "_steps": [
    "1. Firebase Console → Add Android app → package name ca.popuphub.app",
    "2. Download google-services.json into android/app/",
    "3. Firebase → Project settings → Cloud Messaging → copy Server key → Vercel FCM_SERVER_KEY",
    "4. npm run mobile:sync && rebuild"
  ],
