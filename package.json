{
    "name": "popup-hub",
    "version": "1.159.0",
    "private": true,
    "license": "UNLICENSED",
    "scripts": {
        "dev": "next dev",
        "dev:https": "next dev --experimental-https --experimental-https-key ./.cert/localhost-key.pem --experimental-https-cert ./.cert/localhost.pem",
        "dev:certs": "mkcert -install && mkcert -key-file .cert/localhost-key.pem -cert-file .cert/localhost.pem localhost 127.0.0.1 ::1",
        "prebuild": "node scripts/clean-next-build.mjs --strict --stop-dev && node scripts/bump-build-number.mjs",
        "build": "node --max-old-space-size=8192 ./node_modules/next/dist/bin/next build --webpack",
        "release": "npm version patch && git push && git push --tags",
        "version:patch": "npm version patch --no-git-tag-version",
        "version:minor": "npm version minor --no-git-tag-version",
        "version:major": "npm version major --no-git-tag-version",
        "version:sync-history": "node scripts/bump-package-version.mjs --from-history",
        "version:from-commit": "node scripts/bump-package-version.mjs --message",
        "start": "next start",
        "lint": "eslint",
        "db:push": "npx supabase db push",
        "seed:edmonton:import": "npx tsx scripts/import-edmonton-seed.ts",
        "seed:edmonton:publish": "npx tsx scripts/publish-edmonton-organizers.ts",
        "db:diff": "npx supabase db diff",
        "db:reset": "npx supabase db reset",
        "env:vercel": "powershell -ExecutionPolicy Bypass -File ./scripts/sync-vercel-env.ps1",
        "env:vercel:dry": "powershell -ExecutionPolicy Bypass -File ./scripts/sync-vercel-env.ps1 -DryRun",
        "verify:prod": "powershell -ExecutionPolicy Bypass -File ./scripts/verify-production.ps1",
        "verify:local-https": "powershell -ExecutionPolicy Bypass -File ./scripts/verify-production.ps1 -BaseUrl https://localhost:3000",
        "ship": "powershell -ExecutionPolicy Bypass -File ./scripts/ship.ps1 -Message",
        "assets:logo": "node scripts/process-logo.mjs",
        "assets:hubguard": "node scripts/process-hubguard-logo.mjs",
        "qa:layout": "npx tsx lib/booth-planner/qa-scenarios.ts",
        "qa:regression": "npx tsx lib/booth-planner/qa-regression-100.ts",
        "qa:launch": "powershell -ExecutionPolicy Bypass -File ./scripts/launch-qa.ps1",
        "qa:launch:fast": "powershell -ExecutionPolicy Bypass -File ./scripts/launch-qa.ps1 -SkipBuild",
        "qa:market-features": "npx tsx scripts/smoke-market-features.ts",
        "qa:market-features:configure": "npx tsx scripts/configure-market-features-test-event.ts",
        "qa:a2-walkthrough": "npx tsx scripts/a2-coordinator-loop-walkthrough.ts",
        "qa:workflow": "powershell -ExecutionPolicy Bypass -File ./scripts/qa-full-workflow.ps1",
        "qa:workflow:staging": "powershell -ExecutionPolicy Bypass -File ./scripts/qa-full-workflow.ps1 -StagingSmoke",
        "qa:workflow:walkthrough": "npx tsx scripts/qa-full-workflow-walkthrough.ts",
        "qa:handoff": "powershell -ExecutionPolicy Bypass -File ./scripts/send-qa-handoff.ps1",
        "qa:automation": "powershell -ExecutionPolicy Bypass -File ./scripts/run-qa-automation.ps1",
        "qa:automation:static": "powershell -ExecutionPolicy Bypass -File ./scripts/run-qa-automation.ps1 -SkipPlaywright",
        "qa:automation:prod": "powershell -ExecutionPolicy Bypass -File ./scripts/run-qa-automation.ps1 -ProdBrowser",
        "test:unit": "npx tsx lib/vendor-fairness-layout/geometry/geometry.test.ts && npx tsx lib/vendor-fairness-layout/integration.test.ts && npx tsx components/coordinator/floor-plan-v2/geometry/polygon-edit.test.ts && npx tsx components/coordinator/floor-plan-v2/interactions/category-rules.test.ts && npx tsx lib/floor-plan/door-clearance-zones.test.ts && npx tsx lib/applications/payment-deadline.test.ts && npx tsx lib/applications/payment-reminder-schedule.test.ts && npx tsx lib/auth/email-confirmation.test.ts && npx tsx lib/portals/qa-active-portal.ts",
        "test:fairness-layout": "npx tsx lib/vendor-fairness-layout/geometry/geometry.test.ts && npx tsx lib/vendor-fairness-layout/integration.test.ts",
        "test:fairness-layout:stress": "npx tsx scripts/verify-vendor-fairness-layout.ts",
        "test:shopper-routing": "npx tsx lib/shopper/qa-pathfinding.ts",
        "test:shopper-routing:live": "npx tsx lib/shopper/qa-live-layout.ts",
        "test:rbac-signup": "npx tsx lib/auth/qa-rbac-signup.ts",
        "seed:test-users": "npx tsx scripts/seed-test-users.ts",
        "test:e2e": "playwright test",
        "test:e2e:workflow": "playwright test tests/e2e/workflow --project=workflow",
        "test:e2e:matrix": "playwright test tests/e2e/device-matrix.spec.ts",
        "test:e2e:pwa": "playwright test tests/e2e/pwa-secure-context.spec.ts",
        "test:e2e:shopper-floorplan": "playwright test tests/e2e/shopper-floorplan.spec.ts",
        "test:e2e:public-discovery": "playwright test tests/e2e/public-discovery.spec.ts",
        "test:e2e:canopy": "playwright test tests/e2e/canopy-trust.spec.ts",
        "test:e2e:discover-ux": "playwright test tests/e2e/discover-ux.spec.ts",
        "test:e2e:smoke": "playwright test tests/e2e/public-discovery.spec.ts tests/e2e/canopy-trust.spec.ts tests/e2e/discover-ux.spec.ts",
        "test:e2e:mobile": "playwright test tests/e2e/patron-mobile-chrome.spec.ts tests/e2e/vendor-mobile-chrome.spec.ts tests/e2e/vendor-quick-apply.spec.ts",
        "test:e2e:ui": "playwright test --ui",
        "seo:sitemap": "npx tsx scripts/generate-sitemap.ts",
        "mobile:assets": "node scripts/mobile/generate-ios-resources.mjs",
        "mobile:sync": "powershell -ExecutionPolicy Bypass -File ./scripts/mobile/sync-mobile.ps1",
        "mobile:sync:ios": "powershell -ExecutionPolicy Bypass -File ./scripts/mobile/sync-ios.ps1",
        "mobile:ios:open": "npx cap open ios",
        "mobile:ios:add": "npx cap add ios",
        "mobile:android:add": "npx cap add android",
        "mobile:android:open": "npx cap open android",
        "mobile:android:run": "npx cap run android",
        "mobile:android:debug": "powershell -ExecutionPolicy Bypass -File ./scripts/mobile/build-android-debug.ps1",
        "mobile:store-links": "powershell -ExecutionPolicy Bypass -File ./scripts/mobile/configure-store-links.ps1"
    },
    "dependencies": {
        "@base-ui/react": "^1.5.0",
        "@capacitor/android": "7.6.6",
        "@capacitor/app": "7.1.2",
        "@capacitor/cli": "^7.6.6",
        "@capacitor/core": "^7.6.6",
        "@capacitor/geolocation": "^7.1.8",
        "@capacitor/haptics": "^7.0.2",
        "@capacitor/ios": "^7.6.6",
        "@capacitor/push-notifications": "^7.0.6",
        "@capacitor/splash-screen": "7.0.5",
        "@capacitor/status-bar": "7.0.6",
        "@dagrejs/dagre": "^3.0.0",
        "@hookform/resolvers": "^5.2.2",
        "@square/web-payments-sdk-types": "^1.83.6",
        "@supabase/auth-ui-react": "^0.4.7",
        "@supabase/auth-ui-shared": "^0.1.8",
        "@supabase/ssr": "^0.10.3",
        "@supabase/supabase-js": "^2.106.1",
        "@tailwindcss/typography": "^0.5.19",
        "@turf/turf": "^7.3.5",
        "@types/canvas-confetti": "^1.9.0",
        "@types/qrcode": "^1.5.6",
        "@vercel/analytics": "^2.0.1",
        "@vis.gl/react-google-maps": "^1.8.3",
        "@xyflow/react": "^12.10.2",
        "canvas-confetti": "^1.9.4",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "date-fns": "^4.2.1",
        "framer-motion": "^12.40.0",
        "html5-qrcode": "^2.3.8",
        "lucide-react": "^1.16.0",
        "next": "^16.2.9",
        "next-themes": "^0.4.6",
        "polygon-clipping": "^0.15.7",
        "qrcode": "^1.5.4",
        "rbush": "^4.0.1",
        "react": "19.2.4",
        "react-day-picker": "^10.0.1",
        "react-dom": "19.2.4",
        "react-hook-form": "^7.76.0",
        "react-qr-code": "^2.0.21",
        "shadcn": "^4.8.0",
        "sonner": "^2.0.7",
        "square": "^44.1.0",
        "stripe": "^17.7.0",
        "tailwind-merge": "^3.6.0",
        "tailwindcss-animate": "^1.0.7",
        "tw-animate-css": "^1.4.0",
        "twilio": "^6.0.2",
        "web-push": "^3.6.7",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@playwright/test": "^1.60.0",
        "@tailwindcss/postcss": "^4",
        "@types/node": "^20",
        "@types/rbush": "^4.0.0",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "eslint": "^9",
        "eslint-config-next": "16.2.6",
        "supabase": "^2.101.0",
        "tailwindcss": "^4",
        "typescript": "^5"
    }
}
