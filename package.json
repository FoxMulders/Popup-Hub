{
    "name": "popup-hub",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev --experimental-https --experimental-https-key ./.cert/localhost-key.pem --experimental-https-cert ./.cert/localhost.pem",
        "dev:certs": "mkcert -install && mkcert -key-file .cert/localhost-key.pem -cert-file .cert/localhost.pem localhost 127.0.0.1 ::1",
        "build": "next build",
        "start": "next start",
        "lint": "eslint",
        "db:push": "npx supabase db push",
        "db:diff": "npx supabase db diff",
        "db:reset": "npx supabase db reset",
        "qa:layout": "npx tsx lib/booth-planner/qa-scenarios.ts",
        "qa:regression": "npx tsx lib/booth-planner/qa-regression-100.ts",
        "seed:test-users": "npx tsx scripts/seed-test-users.ts",
        "test:e2e": "playwright test",
        "test:e2e:matrix": "playwright test tests/e2e/device-matrix.spec.ts",
        "test:e2e:ui": "playwright test --ui"
    },
    "dependencies": {
        "@base-ui/react": "^1.5.0",
        "@hookform/resolvers": "^5.2.2",
        "@square/web-payments-sdk-types": "^1.83.6",
        "@supabase/auth-ui-react": "^0.4.7",
        "@supabase/auth-ui-shared": "^0.1.8",
        "@supabase/ssr": "^0.10.3",
        "@supabase/supabase-js": "^2.106.1",
        "@tailwindcss/typography": "^0.5.19",
        "@types/canvas-confetti": "^1.9.0",
        "@types/qrcode": "^1.5.6",
        "@vis.gl/react-google-maps": "^1.8.3",
        "canvas-confetti": "^1.9.4",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "date-fns": "^4.2.1",
        "lucide-react": "^1.16.0",
        "next": "16.2.6",
        "next-themes": "^0.4.6",
        "qrcode": "^1.5.4",
        "react": "19.2.4",
        "react-day-picker": "^10.0.1",
        "react-dom": "19.2.4",
        "react-hook-form": "^7.76.0",
        "react-qr-code": "^2.0.21",
        "shadcn": "^4.8.0",
        "sonner": "^2.0.7",
        "square": "^44.1.0",
        "stripe": "^22.1.1",
        "tailwind-merge": "^3.6.0",
        "tailwindcss-animate": "^1.0.7",
        "tw-animate-css": "^1.4.0",
        "twilio": "^6.0.2",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@playwright/test": "^1.60.0",
        "@tailwindcss/postcss": "^4",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "eslint": "^9",
        "eslint-config-next": "16.2.6",
        "supabase": "^2.101.0",
        "tailwindcss": "^4",
        "typescript": "^5"
    }
