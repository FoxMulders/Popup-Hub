# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.key
*.p12
*.cer
.certSigningRequest

# playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/tests/e2e/workflow/.workflow-state.json
/tests/e2e/workflow/.fixtures.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
# local dev / prod server logs (next start -p XXXX > XXXX.log)
dev-*.log
prod-*.log
.commit-message.tmp

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

certificates

# Capacitor / Xcode (synced web assets are regenerated)
/ios/App/App/public/
ios/DerivedData/
*.xcuserstate
**/xcuserdata/